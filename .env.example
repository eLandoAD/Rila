# Copia in .env e compila con i valori reali
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
# Per SMTP reale lasciare true; per il catcher Mailpit locale impostare a false
SMTP_AUTH=true
SMTP_STARTTLS=true
FRONTEND_URL=http://localhost:4200
# JWT_SECRET=...

# DEMO: account già verificati alla registrazione (no mail necessaria per loggarsi).
# Lasciare false in produzione.
DEMO_AUTO_VERIFY=false

# --- Demo / sviluppo (email catturate da Mailpit, UI su :8025) ---
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_AUTH=false
# SMTP_STARTTLS=false
# FRONTEND_URL=http://localhost:4205
# DEMO_AUTO_VERIFY=true
